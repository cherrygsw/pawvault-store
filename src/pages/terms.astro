---
// TEMPLATE DRAFT — NOT LEGAL ADVICE.
// This Terms of Service was generated as a first-draft starting point based
// on what this codebase and store actually do (Wix Stores/eCom checkout,
// third-party supplier fulfillment, US-only shipping, the 30-day return
// policy already published on the site's FAQ page). The store owner must
// review this with a qualified attorney before launch to confirm it is
// accurate, complete, and enforceable, and to fill in the bracketed
// placeholders (governing-law state, business legal name/address).
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icons.astro';

const lastUpdated = 'July 2, 2026';
---

<Layout title="Terms of Service" description="The terms that govern your use of the PawVault website and orders placed with us.">
  <div class="page-inner">

    <div class="page-hero">
      <div class="hero-badge">
        <Icon name="shield" size={13} color="#2D6A4F" aria-hidden={true} />
        <span>Legal</span>
      </div>
      <h1>Terms of Service</h1>
      <p class="last-updated">Last updated: {lastUpdated}</p>
      <p class="intro">
        These terms govern your use of the PawVault website and any order you place with us. By using this site
        or placing an order, you agree to these terms. If you have questions, contact us at
        <a href="mailto:hello@pawvault.com">hello@pawvault.com</a>.
      </p>
    </div>

    <div class="legal-body">

      <section class="legal-section">
        <h2>1. Who we are</h2>
        <p>
          PawVault ("we," "us," or "our") operates this website and sells pet accessories for cats and dogs.
          Products are sourced and fulfilled through third-party suppliers, as described further below.
        </p>
      </section>

      <section class="legal-section">
        <h2>2. Eligibility and use of this site</h2>
        <p>
          You must be able to form a legally binding contract to place an order — generally, you must be at least
          18 years old, or have a parent or guardian's permission. We currently ship orders only within the
          contiguous United States.
        </p>
      </section>

      <section class="legal-section">
        <h2>3. Products and pricing</h2>
        <p>
          We try to keep product descriptions, images, and prices accurate, but errors can happen. If we discover
          a pricing or listing error on an order you've placed, we'll contact you before charging you the
          corrected amount, and you may cancel the order for a full refund if you don't want to proceed. Listing a
          product on this site is not a guarantee that it's in stock — availability is confirmed when your order
          is placed.
        </p>
      </section>

      <section class="legal-section">
        <h2>4. Orders and payment</h2>
        <p>
          When you place an order, checkout and payment are processed through Wix's payment infrastructure and
          payment providers. By placing an order, you authorize us to charge your selected payment method for the
          order total, including applicable shipping and sales tax. Sales tax is calculated based on your delivery
          address and applied at checkout in accordance with applicable state law.
        </p>
      </section>

      <section class="legal-section">
        <h2>5. Shipping and delivery</h2>
        <p>
          We currently ship within the contiguous United States only. Orders over $35 ship free; orders under $35
          have a flat $4.99 shipping fee.
        </p>
        <p>
          Standard shipping typically takes 5–8 business days once an order ships. This is an estimate based on
          typical supplier processing and carrier transit times, not a guaranteed delivery date. Actual delivery
          times can vary depending on the supplier fulfilling your specific order, carrier delays, weather,
          customs or regional disruptions, and other factors outside our control. We are not liable for delays
          caused by our shipping carriers or by circumstances beyond our reasonable control. Once your order
          ships, we'll send you a confirmation email with tracking information.
        </p>
      </section>

      <section class="legal-section">
        <h2>6. Returns and refunds</h2>
        <p>
          We offer 30-day hassle-free returns. If you're not satisfied with your order, email us at
          <a href="mailto:hello@pawvault.com">hello@pawvault.com</a> with your order number and reason for
          return, and we'll arrange a return at no cost to you. Refunds are processed within 3–5 business days of
          receiving your return. If an item arrives damaged, contact us with a photo and we'll send a replacement
          at no charge, without requiring a return.
        </p>
      </section>

      <section class="legal-section">
        <h2>7. Third-party suppliers</h2>
        <p>
          Products sold on this site are sourced through independent third-party suppliers, who manufacture,
          warehouse, and in most cases ship the products you order. We review products before listing them for
          quality, safety, and value, but the suppliers themselves are independent businesses, not employees or
          agents of PawVault.
        </p>
      </section>

      <section class="legal-section">
        <h2>8. Intellectual property</h2>
        <p>
          The text, graphics, logos, and other content on this site belong to PawVault or our licensors and are
          protected by applicable intellectual property laws. You may not copy, reproduce, or use our content for
          commercial purposes without our prior written permission.
        </p>
      </section>

      <section class="legal-section">
        <h2>9. Acceptable use</h2>
        <p>
          You agree not to misuse this site — including attempting unauthorized access to our systems, submitting
          fraudulent orders or payment information, or interfering with the site's normal operation.
        </p>
      </section>

      <section class="legal-section">
        <h2>10. Disclaimer and limitation of liability</h2>
        <p>
          This site and the products sold on it are provided "as is," without warranties of any kind beyond those
          we expressly state or that cannot be excluded under applicable law. To the fullest extent permitted by
          law, PawVault is not liable for any indirect, incidental, or consequential damages arising from your use
          of this site or the products you purchase. Our total liability for any claim relating to an order is
          limited to the amount you paid for that order.
        </p>
      </section>

      <section class="legal-section">
        <h2>11. Governing law</h2>
        <p>
          These terms are governed by the laws of the State of [State], without regard to its conflict-of-law
          principles.
        </p>
      </section>

      <section class="legal-section">
        <h2>12. Changes to these terms</h2>
        <p>
          We may update these terms from time to time. Changes will be posted on this page with a revised "Last
          updated" date above. Your continued use of the site after changes are posted means you accept the
          updated terms.
        </p>
      </section>

      <section class="legal-section">
        <h2>13. Contact us</h2>
        <p>
          Questions about these terms? Email <a href="mailto:hello@pawvault.com">hello@pawvault.com</a>.
        </p>
        <p class="placeholder-note">[Business legal name and mailing address to be added here]</p>
      </section>

    </div>
  </div>
</Layout>

<style>
  :root {
    --green: #2D6A4F;
    --cream: #FFF9F0;
    --terra: #C9663C;
    --dark: #0F1117;
    --gray: #6B7280;
    --border: #E8E3DB;
  }

  .page-inner { max-width: 780px; margin: 0 auto; padding: 64px 24px 96px; }

  .page-hero { margin-bottom: 48px; }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(45,106,79,0.07);
    color: var(--green);
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .page-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--dark);
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }
  .last-updated {
    font-size: 0.85rem;
    color: var(--gray);
    font-weight: 500;
    margin-bottom: 20px;
  }
  .intro { font-size: 1rem; color: #4B5563; line-height: 1.7; }
  .intro a { color: var(--green); font-weight: 500; }

  .legal-body { display: flex; flex-direction: column; gap: 40px; }

  .legal-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--dark);
    letter-spacing: -0.01em;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .legal-section p {
    font-size: 0.95rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 12px;
  }
  .legal-section p:last-child { margin-bottom: 0; }
  .legal-section a { color: var(--green); font-weight: 500; }
  .legal-section strong { color: var(--dark); font-weight: 600; }

  .placeholder-note {
    font-style: italic;
    color: var(--terra);
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .page-inner { padding: 48px 20px 72px; }
  }
</style>
