---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icons.astro';
import { getWixServerClient } from '../lib/wixServerClient';
import { resolveWixImage } from '../lib/wixImage';

let lineItems: any[] = [];
let subtotal: string | null = null;
try {
  const client = await getWixServerClient(Astro.cookies);
  const cart = await client.currentCart.getCurrentCart();
  lineItems = cart?.lineItems ?? [];
  subtotal = lineItems.length > 0
    ? lineItems.reduce((sum: number, li: any) => sum + Number(li.price?.amount ?? 0) * (li.quantity ?? 0), 0).toFixed(2)
    : null;
} catch (e) {
  lineItems = [];
}

---

<Layout title="Your Cart" description="Review the items in your PawVault cart.">
  <div class="page-inner">
    <h1>Your Cart</h1>

    {lineItems.length === 0 ? (
      <div class="empty-state" role="status">
        <div class="empty-icon" aria-hidden="true">
          <Icon name="cart" size={36} color="#C5B9AE" />
        </div>
        <h2>Your cart is empty</h2>
        <p>Browse our <a href="/products">products</a> to find something for your pet.</p>
      </div>
    ) : (
      <div class="cart-layout">
        <div class="cart-items" id="cart-items">
          {lineItems.map((li: any) => (
            <div class="cart-item" data-line-item-id={li._id}>
              <div class="cart-item-img">
                {resolveWixImage(li.image)
                  ? <img src={resolveWixImage(li.image)!} alt={li.productName?.original ?? 'Product'} />
                  : <div class="cart-item-img-placeholder" aria-hidden="true"><Icon name="paw" size={28} color="#C5B9AE" /></div>
                }
              </div>
              <div class="cart-item-info">
                <p class="cart-item-name">{li.productName?.original}</p>
                {(li.descriptionLines ?? []).length > 0 && (
                  <p class="cart-item-variant">
                    {li.descriptionLines
                      .map((d: any) => d.plainText?.original ?? d.colorInfo?.original)
                      .filter(Boolean)
                      .join(' · ')}
                  </p>
                )}
                <p class="cart-item-price">{li.price?.formattedAmount}</p>
              </div>
              <div class="cart-item-qty">
                <button class="qty-btn qty-minus" aria-label="Decrease quantity">−</button>
                <span class="qty-display">{li.quantity}</span>
                <button class="qty-btn qty-plus" aria-label="Increase quantity">+</button>
              </div>
              <button class="remove-btn" aria-label={`Remove ${li.productName?.original} from cart`}>
                Remove
              </button>
            </div>
          ))}
        </div>

        <div class="cart-summary">
          <div class="cart-summary-row">
            <span>Subtotal</span>
            <span id="cart-subtotal">{subtotal ? `$${subtotal}` : 'Calculated at checkout'}</span>
          </div>
          <button class="checkout-btn" id="checkout-btn">Proceed to Checkout</button>
          <a href="/products" class="continue-link">Continue shopping</a>
          <p class="cart-error" id="cart-error" role="alert" aria-live="polite"></p>
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  const itemsContainer = document.getElementById('cart-items');
  const checkoutBtn = document.getElementById('checkout-btn');
  const errorEl = document.getElementById('cart-error')!;

  function showError(msg: string) {
    errorEl.textContent = msg;
  }

  itemsContainer?.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const itemEl = target.closest<HTMLElement>('.cart-item');
    if (!itemEl) return;
    const lineItemId = itemEl.dataset.lineItemId!;

    if (target.closest('.remove-btn')) {
      const res = await fetch('/api/cart/remove', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lineItemId }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        showError('Could not remove item. Please try again.');
      }
      return;
    }

    const isPlus = target.closest('.qty-plus');
    const isMinus = target.closest('.qty-minus');
    if (isPlus || isMinus) {
      const qtyDisplay = itemEl.querySelector('.qty-display')!;
      let qty = parseInt(qtyDisplay.textContent || '1', 10);
      qty = isPlus ? qty + 1 : Math.max(1, qty - 1);

      const res = await fetch('/api/cart/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lineItemId, quantity: qty }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        showError('Could not update quantity. Please try again.');
      }
    }
  });

  checkoutBtn?.addEventListener('click', async () => {
    checkoutBtn.setAttribute('disabled', 'true');
    checkoutBtn.textContent = 'Redirecting…';
    try {
      const res = await fetch('/api/cart/checkout', { method: 'POST' });
      const data = await res.json();
      if (res.ok && data.checkoutUrl) {
        window.location.href = data.checkoutUrl;
      } else {
        showError(data.error || 'Could not start checkout. Please try again.');
        checkoutBtn.removeAttribute('disabled');
        checkoutBtn.textContent = 'Proceed to Checkout';
      }
    } catch {
      showError('Could not start checkout. Please try again.');
      checkoutBtn.removeAttribute('disabled');
      checkoutBtn.textContent = 'Proceed to Checkout';
    }
  });
</script>

<style>
  :root {
    --green: #2D6A4F;
    --cream: #FFF9F0;
    --terra: #C9663C;
    --dark: #0F1117;
    --gray: #6B7280;
    --border: #E8E3DB;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
  }

  .page-inner { max-width: 1000px; margin: 0 auto; padding: 64px 32px 96px; }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: var(--dark);
    margin-bottom: 40px;
  }

  .empty-state {
    background: white;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 72px 48px;
    text-align: center;
  }
  .empty-icon {
    width: 64px;
    height: 64px;
    background: #F5EFE8;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .empty-state h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--dark); margin-bottom: 10px; }
  .empty-state p { color: var(--gray); }
  .empty-state a { color: var(--green); font-weight: 600; }

  .cart-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 40px; align-items: start; }

  .cart-items { display: flex; flex-direction: column; gap: 16px; }
  .cart-item {
    display: grid;
    grid-template-columns: 72px 1fr auto auto;
    gap: 16px;
    align-items: center;
    background: white;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
  }
  .cart-item-img { width: 72px; height: 72px; border-radius: 10px; overflow: hidden; background: #F5EFE8; display: flex; align-items: center; justify-content: center; }
  .cart-item-img img { width: 100%; height: 100%; object-fit: cover; }
  .cart-item-img-placeholder { opacity: 0.5; }
  .cart-item-name { font-weight: 600; font-size: 0.92rem; color: var(--dark); margin-bottom: 4px; }
  .cart-item-variant { font-size: 0.8rem; color: var(--gray); margin-bottom: 4px; }
  .cart-item-price { color: var(--green); font-weight: 700; font-size: 0.9rem; }

  .cart-item-qty { display: flex; align-items: center; border: 1.5px solid var(--border); border-radius: 8px; overflow: hidden; }
  .qty-btn { width: 32px; height: 36px; background: white; border: none; cursor: pointer; font-size: 1rem; }
  .qty-btn:hover { background: var(--cream); }
  .qty-display { width: 32px; text-align: center; font-weight: 600; font-size: 0.9rem; }

  .remove-btn {
    background: none;
    border: none;
    color: var(--gray);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    padding: 6px 10px;
  }
  .remove-btn:hover { color: var(--terra); }

  .cart-summary {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    position: sticky;
    top: 80px;
  }
  .cart-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    color: var(--dark);
    margin-bottom: 20px;
    font-weight: 600;
  }
  .checkout-btn {
    width: 100%;
    background: var(--green);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    margin-bottom: 12px;
    transition: background 0.15s;
  }
  .checkout-btn:hover { background: #235c43; }
  .checkout-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .continue-link { display: block; text-align: center; color: var(--green); font-size: 0.875rem; font-weight: 500; }
  .cart-error { color: var(--terra); font-size: 0.85rem; margin-top: 12px; min-height: 1em; }

  @media (max-width: 720px) {
    .cart-layout { grid-template-columns: 1fr; }
    .cart-item { grid-template-columns: 56px 1fr; grid-template-rows: auto auto; }
    .cart-item-qty, .remove-btn { grid-column: 2; }
  }
</style>
